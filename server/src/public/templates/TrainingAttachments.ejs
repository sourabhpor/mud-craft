<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Training Attachments</title>
        <style type="text/css">
            @font-face {
                font-family: "flama-condensed";
                font-weight: 100;
                src: url("http://assets.vervewine.com/fonts/FlamaCond-Medium.eot");
                src: url("http://assets.vervewine.com/fonts/FlamaCond-Medium.eot?#iefix") format("embedded-opentype"), 
                     url("http://assets.vervewine.com/fonts/FlamaCond-Medium.woff") format("woff"),
                     url("http://assets.vervewine.com/fonts/FlamaCond-Medium.ttf") format("truetype");
            }
            @font-face {
                font-family: "Muli";
                font-weight: 100;
                src: url("http://assets.vervewine.com/fonts/muli-regular.eot");
                src: url("http://assets.vervewine.com/fonts/muli-regular.eot?#iefix") format("embedded-opentype"), 
                     url("http://assets.vervewine.com/fonts/muli-regular.woff2") format("woff2"),
                     url("http://assets.vervewine.com/fonts/muli-regular.woff") format("woff"), 
                     url("http://assets.vervewine.com/fonts/muli-regular.ttf") format("truetype");
            }
            body {
                margin: 0;
                padding: 0;
                background-color: #e1e5e8;
                font-family: 'Muli', Arial, sans-serif;
            }
            .main-center {
                width: 100%;
                table-layout: fixed;
                -webkit-text-size-adjust: 100%;
                -ms-text-size-adjust: 100%;
                background-color: #e1e5e8;
                display: flex;
                justify-content: center;
                padding: 20px 0;
            }
            .main-table {
                border-spacing: 0;
                font-family: 'Muli', Arial, sans-serif;
                color: #333333;
                margin: 0 auto;
                width: 100%;
                max-width: 600px;
                background-color: #ffffff;
            }
            .td-padding {
                padding-top: 15px;
                padding-bottom: 15px;
                padding-right: 30px;
                padding-left: 30px;
            }
            .header-title {
                margin: 0;
                text-align: center;
                font-family: 'flama-condensed', 'Arial Narrow', Arial;
                font-weight: 100;
                font-size: 30px;
                margin-bottom: 26px;
                color: #333;
            }
            .main-content {
                color: rgb(161, 168, 173);
                font-family: 'Muli', Arial, sans-serif;
                font-size: 15px;
                line-height: 25px;
                text-align: left;
                background-color: rgb(255, 255, 255);
            }
            .training-details {
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                border-radius: 12px;
                padding: 25px;
                margin: 25px 0;
                box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            }
            .training-details h3 {
                color: #ffffff;
                margin-top: 0;
                margin-bottom: 20px;
                font-family: 'flama-condensed', 'Arial Narrow', Arial;
                font-size: 22px;
                font-weight: 600;
            }
            .training-details p {
                margin: 12px 0;
                color: #ffffff;
                font-family: 'Muli', Arial, sans-serif;
                font-size: 15px;
                line-height: 1.6;
            }
            .training-details strong {
                color: #ffffff;
                font-weight: 600;
                display: inline-block;
                min-width: 140px;
            }
            .attachment-info {
                background-color: #f8f9fa;
                border-radius: 8px;
                padding: 20px;
                margin: 20px 0;
                border-left: 4px solid #667eea;
            }
            .attachment-info p {
                margin: 8px 0;
                color: #333;
                font-family: 'Muli', Arial, sans-serif;
                font-size: 15px;
            }
            .attachment-icon {
                font-size: 24px;
                margin-right: 10px;
                vertical-align: middle;
            }
            .contact {
                font-family: 'Muli', Arial, sans-serif;
                margin: 0;
                text-align: center;
                font-size: 15px;
                color: #a1a8ad;
                line-height: 23px;
            }
            .contacttd {
                padding-top: 0;
                padding-bottom: 0;
                padding-right: 30px;
                padding-left: 30px;
                text-align: center;
            }
            .address {
                font-family: 'Muli', Arial, sans-serif;
                margin: 0;
                text-align: center;
                padding-top: 10px;
                padding-bottom: 30px;
                font-size: 15px;
                color: #a1a8ad;
                line-height: 23px;
            }
            .message-content {
                background-color: #ffffff;
                padding: 20px;
                border-radius: 8px;
                margin: 20px 0;
                line-height: 1.8;
                color: #333;
            }
            a {
                color: #667eea;
                text-decoration: none;
            }
            a:hover {
                text-decoration: underline;
            }
        </style>
    </head>
    <body bgcolor="#e1e5e8">
        <center class="main-center">
            <div style="max-width: 600px; margin: 0 auto;">
                <table align="center" cellpadding="0" class="main-table" style="border-spacing: 0;">
                    <tbody>
                        <tr>
                            <td class="one-column" style="padding: 0; background-color: #ffffff;">
                                <table style="border-spacing: 0;" width="100%">
                                    <tbody>
                                        <!-- Logo -->
                                        <tr>
                                            <td align="center" class="inner td-padding" valign="middle">
                                                <img alt="Crest Connect" class="banner" height="93" 
                                                     src="https://crest-connect-dev-new.s3.ap-south-1.amazonaws.com/crest-connect-logo.png" 
                                                     style="border-width: 0px; margin-top: 30px; width: 255px; height: auto;" 
                                                     width="255" />
                                            </td>
                                        </tr>
                                        
                                        <!-- Title -->
                                        <tr>
                                            <td class="inner contents center td-padding" style="text-align: center;">
                                                <h1 class="header-title">📎 Training Attachments</h1>
                                            </td>
                                        </tr>
                                        
                                        <!-- Message Content -->
                                        <tr>
                                            <td class="inner contents center td-padding" style="text-align: left;">
                                                <div class="message-content">
                                                    <p style="margin: 0 0 15px 0; color: rgb(161, 168, 173); font-size: 15px;">
                                                        Hi there,
                                                    </p>
                                                    <div style="color: #333; font-size: 15px; line-height: 1.8;">
                                                        <%- message %>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                        
                                        <!-- Training Details -->
                                        <% if (trainingTitle || trainingDate || startTime || endTime) { %>
                                        <tr>
                                            <td class="inner contents center td-padding" style="text-align: left;">
                                                <div class="training-details">
                                                    <h3>📚 Training Information</h3>
                                                    <% if (trainingTitle) { %>
                                                    <p><strong>Title:</strong> <%= trainingTitle %></p>
                                                    <% } %>
                                                    <% if (trainingDescription && trainingDescription.trim() !== '') { %>
                                                    <p style="margin-top: 15px;"><strong>Description:</strong><br/>
                                                    <span style="opacity: 0.95;"><%= trainingDescription %></span></p>
                                                    <% } %>
                                                    <% if (trainingDate) { %>
                                                    <p><strong>📅 Date:</strong> <%= trainingDate %></p>
                                                    <% } %>
                                                    <% if (startTime && endTime) { %>
                                                    <p><strong>⏰ Time:</strong> <%= startTime %> - <%= endTime %></p>
                                                    <% } else if (startTime) { %>
                                                    <p><strong>⏰ Start Time:</strong> <%= startTime %></p>
                                                    <% } else if (endTime) { %>
                                                    <p><strong>⏰ End Time:</strong> <%= endTime %></p>
                                                    <% } %>
                                                    <% if (primaryConductByName && primaryConductByName.trim() !== '') { %>
                                                    <p><strong>👤 Trainer:</strong> <%= primaryConductByName %></p>
                                                    <% } %>
                                                    <% if (conductedBy && conductedBy.trim() !== '') { %>
                                                    <p><strong>🎓 Guest Trainer:</strong> <%= conductedBy %></p>
                                                    <% } %>
                                                </div>
                                            </td>
                                        </tr>
                                        <% } %>
                                        
                                        <!-- Attachment Info -->
                                        <tr>
                                            <td class="inner contents center td-padding" style="text-align: left;">
                                                <div class="attachment-info">
                                                    <p style="margin: 0 0 10px 0; font-weight: 600; color: #667eea; font-size: 16px;">
                                                        <span class="attachment-icon">📄</span>Attached Documents
                                                    </p>
                                                    <p style="margin: 0; color: #666; font-size: 14px;">
                                                        <% if (attachmentCount > 0) { %>
                                                        You have received <strong><%= attachmentCount %></strong> consolidated document(s) containing all training materials.
                                                        <% } else { %>
                                                        Training documents are attached to this email.
                                                        <% } %>
                                                    </p>
                                                </div>
                                            </td>
                                        </tr>
                                        
                                        <!-- Footer Contact -->
                                        <tr>
                                            <td class="contacttd">
                                                <center>
                                                    <p class="contact">
                                                        Problems or questions? Call us at
                                                        <nobr>
                                                            <a class="tel" href="tel:2128102899" style="color: #a1a8ad; text-decoration: none;" target="_blank">
                                                                <span style="white-space: nowrap;">212.810.2899</span>
                                                            </a>
                                                        </nobr>
                                                    </p>
                                                    <p class="contact">
                                                        or email <a href="mailto:info@crestproperty.in" style="color: #a1a8ad; text-decoration: underline;" target="_blank">info@crestproperty.in</a>
                                                    </p>
                                                </center>
                                            </td>
                                        </tr>
                                        
                                        <!-- Footer Address -->
                                        <tr>
                                            <td class="contacttd">
                                                <p class="address">
                                                    © <%= new Date().getFullYear() %> Crest Connect. All rights reserved.
                                                </p>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </center>
    </body>
</html>
