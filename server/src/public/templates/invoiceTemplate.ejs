                                        </tr>
                                        <tr>
                                            <td class="col-6"><%= data.billingAddress.address %>, <%= data.billingAddress.city %>, <%= data.billingAddress.state %>
                                            </td>
                                            <td class="col-6"><%=data.shippingAddress.address%>, <%= data.billingAddress.city %>, <%= data.billingAddress.state %>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="col-6"> <strong> Postcode:</strong>  <%=data.billingAddress.pinCode%> </td>
                                            <td class="col-6"><strong> Postcode: </strong> <%=data.shippingAddress.pinCode%> </td>
                                        </tr>
                                        <tr>
                                            <td class="col-6"><strong> Phone No: </strong> <%=data.billingAddress.phoneNumber%></td>
                                            <td class="col-6"><strong>Phone No: </strong> <%=data.shippingAddress.phoneNumber%> </td>
                                        </tr>
                                        <tr>
                                            <td class="col-6"><strong> GSTIN: </strong></td>
