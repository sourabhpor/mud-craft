                                            <td> <strong>State:</strong> <%=data.billingAddress.state%> </td>
                                            <td><strong>Code</strong></td>
                                            <td> 24 </td>
                                            <td> <strong>Country: IN </strong> </td>
                                            <td> <strong>State: </strong> <%= data.shippingAddress.state %> </td>
                                            <td> <strong> Code </strong> </td>
                                            <td> 24 </td>
                                            <td> <strong> Country: IN </strong> </td>
                                        </tr>
