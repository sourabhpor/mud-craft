                        <tr>
                            <td colspan="2" class="p-0">
                                <table class="table table-sm mb-0 table-bordered" style="width: 100%;">
                                    <thead>
                                        <tr class="bg-light">
                                            <td style="text-align: center;" class="text-center"><strong>#</strong></td>
                                            <td style="text-align: center;" class="text-center"><strong>Item</strong></td>
                                            <td style="text-align: center;" class="text-center"><strong>QTY</strong></td>
                                            <td class="col-3 text-center" style="text-align: center;"><strong>Rate Per Item (Rs.)</strong></td>
                                            <td style="text-align: center;" class="text-center"><strong>Discount Item</strong></td>
                                            <td class="col-3 text-center" style="text-align: center;"><strong> Taxable Item (Rs.) </strong></td>
                                            <td style="text-align: center;" class="text-center"><strong> HSN </strong></td>
                                            <td style="text-align: center;" class="text-center"><strong> GST % </strong></td>
                                            <% if(data?.billingAddress?.stateCode === 'GJ'){ %>
                                                <td style="text-align: center;" class="text-center"><strong> CGST Rs. </strong></td>
                                                <td style="text-align: center;" class="text-center"><strong> SGST Rs. </strong></td>
                                            <% } else{ %>  
                                                <td style="text-align: center;" class="text-center"><strong> IGST Rs. </strong></td>
                                            <% } %>
                                            
                                            <td style="text-align: center;" class="text-center"><strong> Total Rs. </strong></td>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% for(var i=0; i < data?.ordersdetails?.length; i++){ %>
                                            <% 
                                                var price = (data?.ordersdetails[i]?.product?.discountPrice == 0 
                                                            ? data?.ordersdetails[i]?.product?.price 
                                                            : data?.ordersdetails[i]?.product?.discountPrice);
                                            %>
                                            <tr>
                                                <td class="col-1 text-center" style="text-align: center;"><%= i+1 %></td>
                                                <td class="col-6"><%= data?.ordersdetails[i]?.product?.name %></td> 
                                                <td style="text-align: center;" class="text-center"><%= data?.ordersdetails[i]?.quantity %></td> 
                                                
                                                <td style="text-align: center;" class="text-center">₹<%= parseFloat(price * data?.ordersdetails[i]?.quantity)?.toFixed(2) %></td>

                                                <td style="text-align: center;" class="text-center">₹<%= parseFloat(data?.ordersdetails?.[i]?.discountAmount || 0)?.toFixed(2) %></td>

                                                <!-- <td style="text-align: center;" class="text-center"><%= data?.ordersdetails[i]?.product?.taxRate %></td>  -->
                                                 <td style="text-align: center;" class="text-center">₹<%= parseFloat(((
                                                    (price - data?.ordersdetails?.[i]?.discountAmount || 0) - 
                                                    (((price - data?.ordersdetails?.[i]?.discountAmount || 0) * data?.ordersdetails[i]?.product?.taxRate) / (data?.ordersdetails[i]?.product?.taxRate + 100))) * data?.ordersdetails[i]?.quantity)).toFixed(2) %></td>
                                                <td style="text-align: center;" class="text-center"><%= data?.ordersdetails[i]?.product?.hsn %></td>
                                                <td style="text-align: center;" class="text-center"><%= data?.ordersdetails[i]?.product?.taxRate %> %</td>

                                                <% if(data?.billingAddress?.stateCode === 'GJ'){ %>
                                                    <td style="text-align: center;" class="text-center"><%= parseFloat(((((price - data?.ordersdetails?.[i]?.discountAmount || 0) * (data?.ordersdetails[i]?.product?.taxRate)) / ((data?.ordersdetails[i]?.product?.taxRate) + 100)) / 2) * data?.ordersdetails[i]?.quantity).toFixed(2) %></td>

                                                    <td style="text-align: center;" class="text-center"><%= parseFloat(((((price - data?.ordersdetails?.[i]?.discountAmount || 0) * (data?.ordersdetails[i]?.product?.taxRate)) / ((data?.ordersdetails[i]?.product?.taxRate) + 100)) / 2) * data?.ordersdetails[i]?.quantity ).toFixed(2) %></td>
                                                <% } else{ %>  
                                                    <td style="text-align: center;" class="text-center"><%= parseFloat((((((price - data?.ordersdetails?.[i]?.discountAmount || 0) * (data?.ordersdetails[i]?.product?.taxRate / 2)) / ((data?.ordersdetails[i]?.product?.taxRate) + 100))) * 2) * data?.ordersdetails[i]?.quantity).toFixed(2) %></td>
                                                <% } %>

                                                <td style="text-align: center;" class="text-center">₹<%= parseFloat((((((price - ((price * data?.ordersdetails[i]?.product?.taxRate) / (data?.ordersdetails[i]?.product?.taxRate + 100))) * data?.ordersdetails[i]?.quantity) * data?.ordersdetails[i]?.product?.taxRate) / 100) + ((price - ((price * data?.ordersdetails[i]?.product?.taxRate) / (data?.ordersdetails[i]?.product?.taxRate + 100)))) * data?.ordersdetails[i]?.quantity)).toFixed(2) %></td>
                                            </tr>
                                        <% } %> 
                                        <tr>
                                            <td style="text-align: center;" class="text-center bg-light" colspan="2"> <strong> Total </strong> </td>
                                            <td style="text-align: center;" class="text-center"><%=data?.totalQuantity%></td>
                                            <td style="text-align: center;" class="text-center">₹<%=parseFloat(data?.totalActualPrice)?.toFixed(2)%></td>
                                            <td style="text-align: center;" class="text-center">₹<%=parseFloat(data?.couponAmount || 0 )?.toFixed(2)%></td>
                                            <td style="text-align: center;" class="text-center">₹<%=parseFloat(data?.totalTaxablePrice).toFixed(2)%> </td>
                                            <td style="text-align: center;" class="text-center"> - </td>
                                            <td style="text-align: center;" class="text-center">18 %</td>

                                            <% if(data?.billingAddress?.stateCode === 'GJ'){ %>
                                                <td style="text-align: center;" class="text-center"> <%= parseFloat(data.finalTaxAmount).toFixed(2) %> </td>
                                                <td style="text-align: center;" class="text-center"> <%= parseFloat(data.finalTaxAmount).toFixed(2) %> </td>
                                            <% } else{ %>  
                                                <td style="text-align: center;" class="text-center"> <%= parseFloat(data.finalTaxAmount * 2).toFixed(2) %> </td>
                                            <% } %>

                                            <td style="text-align: center;" class="text-center"> ₹<%=parseFloat(data?.totalProductPrice)?.toFixed(2)%> </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" class="p-0">
                                <table class="table table-sm mb-0 table-bordered" style="width: 100%;">
                                    <tbody>
                                        <tr>
                                            <td class="col-6"> <strong> Terms and Conditions </strong> </td>
                                            <td class="col-3"> Total Amount before Tax </td>
                                            <td class="col-3 text-end" style="text-align: end;"> ₹<%=parseFloat(data.totalTaxablePrice).toFixed(2)%> </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="2" class="p-0">
                                <table class="table table-sm mb-0 table-bordered" style="width: 100%;">
                                    <tbody>
                                        <tr>
                                            <td colspan="1" rowspan="6"> <strong> Total Invoice Amount in Words <br>
                                                <%= data.wordTransfer %> Rupees </strong> </td>
                                            <td colspan="2"> Total Tax Amount </td>
                                            <td colspan="2" class="text-end" style="text-align: end;"> ₹<%= parseFloat(data.finalTaxAmount * 2).toFixed(2)%> </td>
                                        </tr>
                                        <tr>
                                            <td> Discount ₹ </td>
                                            <td > ₹<%=data?.couponAmount || 0 %> </td>
                                            <td> Discount </td>
                                            <td colspan="2" class="text-end"> ₹<%=data?.couponAmount || 0 %> </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2"> Shipping Amount </td>
                                            <td colspan="2" class="text-end" style="text-align: end;"> ₹0 </td>
                                        </tr>
                                        <tr>
                                            <td> GST on Shipping </td>
                                            <td> 18% </td>
                                            <td> Shipping GST Amount </td>
                                            <td colspan="2" class="text-end" style="text-align: end;"> ₹0 </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2"> Total Amount After Tax </td>
                                            <td colspan="2" class="text-end" style="text-align: end;"> ₹<%=parseFloat(parseFloat(data?.totalProductPrice) - parseFloat(data?.couponAmount || 0))?.toFixed(2)%> </td>
                                        </tr>
                                        <tr>
                                            <td colspan="2"> <strong>Total</strong> </td>
                                            <td colspan="2" class="text-end" style="text-align: end;"> <strong>₹<%=parseFloat(parseFloat(data?.totalProductPrice) - parseFloat(data?.couponAmount || 0))?.toFixed(2)%></strong> </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>


